# GenTA Studio - Environment Variables

# Database
DATABASE_URL=sqlite+aiosqlite:///./genta.db

# AI Model Mode: "mock" or "live"
AI_MODE=mock

# Claude API (LLM)
ANTHROPIC_API_KEY=

# Google AI Studio (Image: 나노바나나2, Video: Veo 3.1)
GOOGLE_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Upload directory
UPLOAD_DIR=./uploads
